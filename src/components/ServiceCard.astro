---
interface Props {
  href: string;
  title: string;
  description: string;
  icon: string;
}
const { href, title, description, icon } = Astro.props;
---

<a href={href} class="service-card fade-in">
  <div class="service-icon">
    <Fragment set:html={icon} />
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <span class="card-arrow">Mehr erfahren &rarr;</span>
</a>
