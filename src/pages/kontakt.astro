---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../lib/content';

const { frontmatter, html } = getContent('pages/kontakt.md');
const { frontmatter: site } = getContent('site.md');
---

<BaseLayout title={frontmatter.seo_title || frontmatter.title} description={frontmatter.seo_description}>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a> <span>/</span> <span>{frontmatter.title}</span>
      </nav>
      <h1>{frontmatter.title}</h1>
      <p>{frontmatter.subtitle}</p>
    </div>
  </section>

  <article class="detail-content fade-in">
    <Fragment set:html={html} />
  </article>

  <section class="contact">
    <div class="container fade-in">
      <div class="text-center">
        <h2>Direkt erreichen</h2>
        <p>Wähle deinen bevorzugten Kontaktweg</p>
      </div>
      <div class="contact-methods mt-2">
        <a href={`mailto:${site.email}`} class="contact-method">
          <div class="method-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--sage)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13 2 4"/></svg>
          </div>
          <h3>E-Mail</h3>
          <p>{site.email}</p>
        </a>
        <a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener noreferrer" class="contact-method">
          <div class="method-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--sage)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
          </div>
          <h3>WhatsApp</h3>
          <p>{site.phone}</p>
        </a>
        <a href={site.instagram} target="_blank" rel="noopener noreferrer" class="contact-method">
          <div class="method-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--sage)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </div>
          <h3>Instagram</h3>
          <p>@runayoga_berlin</p>
        </a>
        <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="contact-method">
          <div class="method-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--sage)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <h3>Telefon</h3>
          <p>{site.phone}</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
