---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getCollection } from '../lib/content';

const angebote = getCollection('angebote').sort(
  (a, b) => (a.frontmatter.sort_order || 99) - (b.frontmatter.sort_order || 99)
);

const iconMap: Record<string, string> = {
  yoga: '<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="4" r="2"/><path d="M12 6v4"/><path d="M12 14v4"/><path d="M8 10h8"/><path d="M9 18l-3 3"/><path d="M15 18l3 3"/><path d="M8 10l-4 4"/><path d="M16 10l4 4"/></svg>',
  pilates: '<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="1"/></svg>',
  massagen: '<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c-4.97 0-9-2.69-9-6v-2c0-.88.36-1.69.97-2.34"/><path d="M12 22c4.97 0 9-2.69 9-6v-2c0-.88-.36-1.69-.97-2.34"/><path d="M7 11c-1.5 0-3-1.2-3-3s1.5-3 3-3c.3 0 .6 0 .9.1C8.6 3.3 10.1 2 12 2s3.4 1.3 4.1 3.1c.3-.1.6-.1.9-.1 1.5 0 3 1.2 3 3s-1.5 3-3 3"/><path d="M12 11v5"/><path d="M10 16h4"/></svg>',
  heilraum: '<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.42 4.58a5.4 5.4 0 00-7.65 0L12 5.35l-.77-.77a5.4 5.4 0 00-7.65 0 5.4 5.4 0 000 7.65L12 20.65l8.42-8.42a5.4 5.4 0 000-7.65z"/><path d="M12 5.35v7.3"/><path d="M8.35 9h7.3"/></svg>',
  mantra: '<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>',
  jahreskreis: '<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/><path d="M2 12h20"/></svg>',
};

const descriptionMap: Record<string, string> = {
  yoga: 'Präventionskurse, Yin Yoga und Online-Angebote für jedes Level.',
  pilates: 'Stärke deine Körpermitte mit unseren zertifizierten Präventionskursen.',
  massagen: 'Wohlfühl-Massagen und spezielle Pakete für Pre- und Postnatal.',
  heilraum: 'Schamanische Energiemedizin und spirituelle Begleitung.',
  mantra: 'Mantrachanting und Medicine Songs für innere Ruhe und Verbindung.',
  jahreskreis: 'Gemeinsam durch die Zyklen des Jahres mit Ritualen und Gemeinschaft.',
};
---

<BaseLayout
  title="Mein Angebot – Runayoga"
  description="Entdecke das Angebot von Runayoga: Yoga, Pilates, Massagen, Heilraum, Mantra-Singen und Jahreskreis für Frauen in Berlin-Pankow."
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a> <span>/</span> <span>Angebot</span>
      </nav>
      <h1>Mein Angebot</h1>
      <p>Ein ganzheitliches Angebot für Körper, Geist und Seele</p>
    </div>
  </section>

  <!-- Services Grid -->
  <section>
    <div class="container">
      <div class="services-grid">
        {angebote.map(a => (
          <ServiceCard
            href={`/${a.slug}`}
            title={a.frontmatter.title}
            description={descriptionMap[a.slug] || a.frontmatter.subtitle}
            icon={iconMap[a.slug] || ''}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-sage">
    <div class="container">
      <div class="text-center fade-in">
        <h2>Fragen zu meinem Angebot?</h2>
        <p>Ich berate dich gerne persönlich und finde mit dir gemeinsam das passende Angebot.</p>
        <a href="/kontakt" class="btn btn-accent mt-2">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>
</BaseLayout>
