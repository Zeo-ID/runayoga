---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getContent } from '../../lib/content';

export function getStaticPaths() {
  const posts = getCollection('blog');
  return posts.map(p => ({
    params: { slug: p.slug },
    props: p,
  }));
}

const { frontmatter, html } = Astro.props;

function formatDate(date: string | Date): string {
  return new Date(date).toLocaleDateString('de-DE', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={frontmatter.seo_title || frontmatter.title} description={frontmatter.seo_description}>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a> <span>/</span> <a href="/blog">Blog</a> <span>/</span> <span>{frontmatter.title}</span>
      </nav>
      <h1>{frontmatter.title}</h1>
      <p>{formatDate(frontmatter.date)} &middot; von {frontmatter.author}</p>
    </div>
  </section>

  <article class="detail-content fade-in">
    <Fragment set:html={html} />
  </article>

  <div style="max-width:800px;margin:0 auto;padding:0 2rem 4rem">
    <a href="/blog" class="btn btn-outline">&larr; Zurück zum Blog</a>
  </div>
</BaseLayout>
