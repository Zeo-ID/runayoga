---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getContent } from '../lib/content';

const { frontmatter } = getContent('home.md');
const { frontmatter: siteData } = getContent('site.md');
const siteUrl = Astro.site?.origin || 'https://example.pages.dev';

const services = [
  {
    slug: 'service-1',
    title: 'Leistung 1',
    description: 'Beschreibung der ersten Leistung. Wird aus der Content-Datei geladen.',
    icon: '<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>',
  },
  {
    slug: 'service-2',
    title: 'Leistung 2',
    description: 'Beschreibung der zweiten Leistung. Wird aus der Content-Datei geladen.',
    icon: '<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>',
  },
  {
    slug: 'service-3',
    title: 'Leistung 3',
    description: 'Beschreibung der dritten Leistung. Wird aus der Content-Datei geladen.',
    icon: '<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>',
  },
];

const aboutParagraphs = frontmatter.about_text.split('\n\n');

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": siteData.name,
  "description": frontmatter.seo_description,
  "url": siteUrl,
  "email": siteData.email,
  "telephone": siteData.phone,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": siteData.address,
    "addressCountry": "DE"
  },
  "priceRange": "$$",
  "image": `${siteUrl}/images/hero.jpg`
});
---

<BaseLayout title={frontmatter.seo_title} description={frontmatter.seo_description} ogUrl={`${siteUrl}/`}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-text">
      <h1>Finde deine <em>innere Harmonie</em></h1>
      <p>{frontmatter.hero_subtitle}</p>
      <div class="hero-buttons">
        <a href={frontmatter.hero_cta_link} class="btn btn-primary">{frontmatter.hero_cta_text}</a>
        <a href={frontmatter.hero_cta_secondary_link} class="btn btn-outline">{frontmatter.hero_cta_secondary_text}</a>
      </div>
    </div>
    <div class="hero-image">
      <img src={frontmatter.hero_image} alt={frontmatter.hero_image_alt} loading="eager">
    </div>
    <div class="blob-1"></div>
    <div class="blob-2"></div>
  </section>

  <!-- Services Teaser -->
  <section class="services" id="angebot">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">{frontmatter.services_label}</span>
        <h2>{frontmatter.services_title}</h2>
        <p>{frontmatter.services_subtitle}</p>
      </div>
      <div class="services-grid">
        {services.map(s => (
          <ServiceCard
            href={`/${s.slug}`}
            title={s.title}
            description={s.description}
            icon={s.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Philosophy Quote -->
  <section class="philosophy">
    <div class="philosophy-inner fade-in">
      <blockquote>
        &bdquo;{frontmatter.philosophy_quote}&ldquo;
      </blockquote>
      <cite>&mdash; {frontmatter.philosophy_cite}</cite>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="about" id="about">
    <div class="container">
      <div class="about-inner fade-in">
        <img src={frontmatter.about_image} alt={frontmatter.about_image_alt} loading="lazy">
        <div>
          <span class="section-label">{frontmatter.about_label}</span>
          <h2>{frontmatter.about_title}</h2>
          {aboutParagraphs.map((p: string) => (
            <p>{p}</p>
          ))}
          <a href="/ueber-mich" class="btn btn-primary mt-2">Mehr erfahren</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Retreat Teaser -->
  <section class="retreat" id="retreat">
    <div class="container">
      <div class="retreat-inner fade-in">
        <img src={frontmatter.retreat_image} alt={frontmatter.retreat_image_alt} loading="lazy">
        <div>
          <span class="section-label">{frontmatter.retreat_label}</span>
          <h2>{frontmatter.retreat_title}</h2>
          <p>{frontmatter.retreat_text}</p>
          <ul class="retreat-highlights">
            <li>
              <span class="highlight-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
              </span>
              {frontmatter.retreat_highlights[0]}
            </li>
            <li>
              <span class="highlight-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.42 4.58a5.4 5.4 0 00-7.65 0L12 5.35l-.77-.77a5.4 5.4 0 00-7.65 0 5.4 5.4 0 000 7.65L12 20.65l8.42-8.42a5.4 5.4 0 000-7.65z"/></svg>
              </span>
              {frontmatter.retreat_highlights[1]}
            </li>
            <li>
              <span class="highlight-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
              </span>
              {frontmatter.retreat_highlights[2]}
            </li>
            <li>
              <span class="highlight-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
              </span>
              {frontmatter.retreat_highlights[3]}
            </li>
          </ul>
          <a href="/retreat" class="btn btn-primary mt-2">Retreat anfragen</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials bg-white" id="feedback">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">{frontmatter.testimonials_label}</span>
        <h2>{frontmatter.testimonials_title}</h2>
      </div>
      <div class="testimonials-grid">
        {frontmatter.testimonials.map((t: { quote: string; author: string; stars: number }) => (
          <div class="testimonial-card fade-in">
            <div class="stars">{Array(t.stars).fill('\u2605').join('')}</div>
            <p class="quote">{t.quote}</p>
            <div class="author">{t.author}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA / Contact -->
  <section class="contact" id="kontakt">
    <div class="container">
      <div class="text-center fade-in">
        <h2>{frontmatter.cta_title}</h2>
        <p>{frontmatter.cta_text}</p>
      </div>
      <div class="contact-methods fade-in">
        <a href={`mailto:${siteData.email}`} class="contact-method">
          <div class="method-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--sage)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M22 4L12 13 2 4"/>
            </svg>
          </div>
          <h3>E-Mail</h3>
          <p>{siteData.email}</p>
        </a>
        <a href={`https://wa.me/${siteData.whatsapp}`} class="contact-method" target="_blank" rel="noopener noreferrer">
          <div class="method-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--sage)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/>
            </svg>
          </div>
          <h3>WhatsApp</h3>
          <p>Nachricht senden</p>
        </a>
        <a href={siteData.instagram} class="contact-method" target="_blank" rel="noopener noreferrer">
          <div class="method-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--sage)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </div>
          <h3>Instagram</h3>
          <p>Instagram</p>
        </a>
        <a href={`tel:${siteData.phone?.replace(/\s/g, '')}`} class="contact-method">
          <div class="method-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--sage)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
            </svg>
          </div>
          <h3>Anrufen</h3>
          <p>{siteData.phone}</p>
        </a>
      </div>
      <p class="text-center fade-in">{siteData.address}</p>
    </div>
  </section>
</BaseLayout>
