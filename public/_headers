/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src https://fonts.gstatic.com data:; img-src 'self' data: https://*.githubusercontent.com; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://unpkg.com; connect-src 'self' https://api.github.com https://github.com

/admin/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://unpkg.com 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com data:; img-src 'self' data: https://*.githubusercontent.com https://raw.githubusercontent.com; connect-src 'self' https://api.github.com https://github.com; frame-src 'none'
  X-Frame-Options: SAMEORIGIN
